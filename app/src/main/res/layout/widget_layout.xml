<?xml version="1.0" encoding="utf-8"?>
<!--
  Full list widget — used for all sizes ≥ ~150×100dp.
  LinearLayout (vertical): header | ListView (weight=1, fills remaining height) | footer
  The ListView naturally shows as many rows as fit the available height.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="@drawable/widget_header_bg"
        android:paddingStart="13dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="newspecs"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textAllCaps="true" />

        <!-- Live badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● updating"
            android:textColor="@color/green"
            android:textSize="7sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/live_badge_bg"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/update_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/text_faint"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/reload_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_reload"
            android:background="@drawable/reload_button_bg"
            android:padding="6dp"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- News list — fills all remaining height -->
    <ListView
        android:id="@+id/news_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/border"
        android:dividerHeight="1dp"
        android:paddingStart="13dp"
        android:paddingEnd="13dp"
        android:scrollbars="none" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Loading…"
        android:textColor="@color/text_faint"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="@drawable/widget_header_bg"
        android:paddingStart="13dp"
        android:paddingEnd="13dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/story_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="— stories · &lt;24h"
            android:textColor="@color/text_faint"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/next_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻ 5 min"
            android:textColor="@color/text_faint"
            android:textSize="8sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

    </LinearLayout>

</LinearLayout>
