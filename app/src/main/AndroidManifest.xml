<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Needed to fetch data even when the device is idle -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- ForegroundService — required to call startForeground() -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+ requires a type-specific foreground service permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Newspecs">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          AppWidgetProvider — receives APPWIDGET_UPDATE, our custom refresh actions,
          and exposes the widget metadata via the appwidget meta-data tag.
        -->
        <receiver
            android:name=".widget.NewsWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.newspecs.AUTO_REFRESH" />
                <action android:name="com.newspecs.MANUAL_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!--
          RemoteViewsService — provides the factory that backs the news ListView.
          Must be exported with BIND_REMOTEVIEWS permission so the launcher can bind to it.
        -->
        <service
            android:name=".widget.NewsWidgetService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!--
          NewsRefreshService — ForegroundService that performs the network fetch.
          Replaces the old goAsync() approach; has no time limit so the fetch
          always completes even on slow connections / Doze-waking radios.
          foregroundServiceType="dataSync" is required on API 34+.
        -->
        <service
            android:name=".widget.NewsRefreshService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
          BootReceiver — reschedules the 5-min AlarmManager alarm after a device reboot
          so the widget keeps refreshing without user interaction.
        -->
        <receiver
            android:name=".widget.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
